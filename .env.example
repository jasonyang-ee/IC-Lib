# IC Component Library - Development Environment Configuration
# Copy this file to .env and update with your actual values for local development.

# JWT Authentication
JWT_SECRET=change-this-to-a-secure-random-string-in-production-minimum-32-characters

# Database Configuration
DB_HOST=ip_address_or_hostname
DB_PORT=5432
DB_USER=username
DB_PASSWORD=password
DB_NAME=database_name

# Server Configuration
PORT=3500
NODE_ENV=development
VITE_API_URL=http://localhost:3500/api
CORS_ORIGIN=http://localhost:5173

# Feature Toggles
CONFIG_ECO=false
VITE_CONFIG_ECO=false

# External app URL used in email links
CONFIG_BASE_URL=http://localhost:5173

# Optional subdirectory when the app is reverse-proxied under a path like /iclib/
# CONFIG_SUBDIRECTORY_PATH=/iclib/

# API Keys (Optional - for vendor integrations)
DIGIKEY_CLIENT_ID=your_digikey_client_id
DIGIKEY_CLIENT_SECRET=your_digikey_client_secret
MOUSER_API_KEY=your_mouser_api_key
